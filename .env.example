NEXT_PUBLIC_STORAGE_MODE=local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# NEXT_PUBLIC_STORAGE_MODE accepts local or supabase.
# local is the default mode and requires no Supabase configuration.
# NEXT_PUBLIC_SUPABASE_ANON_KEY and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY are alternatives; configure one public key.
# SUPABASE_SERVICE_ROLE_KEY and SUPABASE_SECRET_KEY are alternatives; configure one server-side key for route handlers only.
# Never commit .env.local. Never expose service role or secret keys to browser code.
